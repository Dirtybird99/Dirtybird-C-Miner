{
  "test_environment": {
    "daemon_address": "203.0.113.10",
    "port": 10100,
    "wallet": "DERO_WALLET_PLACEHOLDER",
    "threads": 20
  },
  "benchmark_settings": {
    "runs_per_config": 3,
    "duration_seconds": 60,
    "warmup_seconds": 15,
    "cooldown_seconds": 5
  },
  "target_metrics": {
    "mean_hashrate_min": 18.0,
    "cv_max_percent": 5.0,
    "stability_ratio_min": 0.85,
    "min_hashrate_floor": 15.0
  },
  "statistical_thresholds": {
    "p_value_significance": 0.05,
    "effect_size_meaningful": 0.2,
    "cv_increase_max_percent": 20
  },
  "configurations": [
    {
      "name": "baseline_no_spsa",
      "description": "Baseline without SPSA optimization",
      "flags": ["--no-spsa"],
      "is_baseline": true
    },
    {
      "name": "default_spsa",
      "description": "Default with SPSA enabled",
      "flags": []
    },
    {
      "name": "cache_batch",
      "description": "Cache-focused batched mining (k1 optimization)",
      "flags": ["--cache-batch"]
    },
    {
      "name": "sa_tune",
      "description": "SA prefetch autotuning enabled",
      "flags": ["--sa-tune"]
    },
    {
      "name": "cache_batch_sa_tune",
      "description": "Combined cache batch + SA tuning",
      "flags": ["--cache-batch", "--sa-tune"]
    },
    {
      "name": "no_lock",
      "description": "Disable CPU affinity",
      "flags": ["--no-lock"]
    },
    {
      "name": "no_lock_cache_batch",
      "description": "No CPU affinity + cache batch",
      "flags": ["--no-lock", "--cache-batch"]
    },
    {
      "name": "no_lock_sa_tune",
      "description": "No CPU affinity + SA tuning",
      "flags": ["--no-lock", "--sa-tune"]
    },
    {
      "name": "no_lock_combined",
      "description": "No CPU affinity + cache batch + SA tuning",
      "flags": ["--no-lock", "--cache-batch", "--sa-tune"]
    },
    {
      "name": "spsa_cache_batch",
      "description": "SPSA + cache batch combined",
      "flags": ["--cache-batch"]
    },
    {
      "name": "cache_batch_hybrid",
      "description": "Auto-detect best mining mode",
      "flags": ["--cache-batch-hybrid"]
    }
  ],
  "sa_prefetch_sweep": {
    "description": "Manual SA prefetch distance sweep",
    "parameter_format": "--sa-prefetch sa,text,bucket",
    "configurations": [
      {"name": "sa_prefetch_8_8_4", "flags": ["--sa-prefetch", "8,8,4"]},
      {"name": "sa_prefetch_16_8_4", "flags": ["--sa-prefetch", "16,8,4"]},
      {"name": "sa_prefetch_16_16_8", "flags": ["--sa-prefetch", "16,16,8"]},
      {"name": "sa_prefetch_16_24_8", "flags": ["--sa-prefetch", "16,24,8"]},
      {"name": "sa_prefetch_24_16_8", "flags": ["--sa-prefetch", "24,16,8"]},
      {"name": "sa_prefetch_32_16_8", "flags": ["--sa-prefetch", "32,16,8"]}
    ]
  },
  "omp_thread_sweep": {
    "description": "OpenMP threads per mining thread sweep",
    "configurations": [
      {"name": "omp_1", "flags": ["--omp-threads", "1"]},
      {"name": "omp_2", "flags": ["--omp-threads", "2"]},
      {"name": "omp_4", "flags": ["--omp-threads", "4"]}
    ]
  }
}
