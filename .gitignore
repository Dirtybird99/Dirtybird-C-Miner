# Build products
/build/
/build-*/
/CMakeFiles/
/CMakeCache.txt
/cmake_install.cmake
/Testing/
*.o
*.obj
*.a
*.dll
*.exe
*.d
*.rsp
*.profdata
*.profraw

# Runtime captures and generated reports
/captures/
/reports/

# Logs and command output
*.log
*.out
*.err
*.jsonl

# Python/test caches
__pycache__/
.pytest_cache/
*.pyc

# Local backups and temporary files
*.bak
/out.txt
tmp/
tmp-*/
temp*

# Binary dumps and process dumps stay local unless explicitly force-added.
*.bin
*.dmp

# Wallet / database files — NEVER commit (the miner does not create these; this is a guard).
*.db
wallet.db

# Editor/OS noise
.DS_Store
Thumbs.db
desktop.ini
/dist/
